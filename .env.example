# Tournament edition (defaults to 2026)
VITE_TOURNAMENT_YEAR=2026

# Optional: override with a single custom JSON URL (skips multi-source chain)
# VITE_TOURNAMENT_DATA_URL=https://example.com/worldcup.json

# --- Optional free API keys (enable extra data sources) ---
# football-data.org — free tier, 10 req/min: https://www.football-data.org/client/register
# VITE_FOOTBALL_DATA_TOKEN=

# API-Football (API-Sports) — free tier, 100 req/day: https://www.api-football.com/
# VITE_API_FOOTBALL_KEY=

# Zafronix World Cup API — free tier, 250 req/day: https://api.zafronix.com/
# VITE_ZAFRONIX_API_KEY=

# Always active without keys: openfootball, Fjelstul (1930–2022), worldcup26.ir (2026)
